# Supabase 專案設定(與 aido-agent-web 共用同一個 Supabase 專案)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role key，僅供伺服器端 API route 使用（bypass RLS），絕不可暴露到前端
SUPABASE_SERVICE_ROLE_KEY=

# Lighthouse/效能稽核繞過用的 bypass token（自訂任意字串，伺服器端與稽核腳本需一致）
AUDIT_BYPASS_TOKEN=

# 企業 SSO 登入開關：true 才會在登入頁顯示 Google/Azure AD 登入按鈕。
# 啟用前需先在 Supabase Dashboard → Authentication → Providers 設定對應 OAuth provider。
NEXT_PUBLIC_ENABLE_SSO=false
